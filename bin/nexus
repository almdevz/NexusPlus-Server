 1|01)create_user;;2|02)create_trial;;3|03)delete_user;;4|04)online_users;;5|05)change_expiry;;6|06)change_limit;;7|07)change_password;;8|08)clean_expired;;9|09)user_report;;10)connection_menu;;11)speedtest_run;;12)banner_manage;;13)traffic_monitor;;14)optimize_network;;15)backup_menu;;16)swap_manage;;17)limiter_status;;18)badvpn_manage;;19)app_online_menu;;20)info_vps;;21)xhttp_menu;;22)health_menu;;0|00)exit 0;;*)warn 'Opção inválida';sleep 1;;esac
