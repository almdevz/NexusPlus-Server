#!/usr/bin/env bash
set -Eeuo pipefail
PATH=/usr/sbin:/usr/bin:/sbin:/bin
LIMITS=/etc/nexusplus/limits.conf
RUN=/run/nexusplus/sessions
LOCK=/run/nexusplus/pam-limit.lock
filter=${1:-}
[[ -r "$LIMITS" ]] || exit 0
install -d -m 0755 /run/nexusplus "$RUN"
exec 9>"$LOCK"; flock -x 9
while IFS='=' read -r u limit; do
  [[ -z "$filter" || "$filter" == "$u" ]] || continue
  [[ "$u" =~ ^[a-z_][a-z0-9_-]{0,30}$ && "$limit" =~ ^[0-9]+$ ]] || continue
  d="$RUN/$u"; [[ -d "$d" ]] || continue
  valid=()
  while IFS= read -r f; do
    IFS=$'\t' read -r pid start _ < "$f" || true
    if [[ "$pid" =~ ^[0-9]+$ && -r "/proc/$pid/stat" && "$(awk '{print $22}' "/proc/$pid/stat" 2>/dev/null)" == "$start" ]]; then
      valid+=("$f")
    else
      rm -f "$f"
    fi
  done < <(find "$d" -maxdepth 1 -type f -name '*.session' -printf '%T@ %p\n' 2>/dev/null | sort -n | cut -d' ' -f2-)
  count=${#valid[@]}
  if (( count > limit )); then
    for ((i=limit; i<count; i++)); do
      f=${valid[$i]}; IFS=$'\t' read -r pid _ _ < "$f" || true
      cmd=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null || true)
      if [[ "$cmd" == *sshd* ]]; then kill -TERM "$pid" 2>/dev/null || true; sleep 0.2; kill -KILL "$pid" 2>/dev/null || true; fi
      rm -f "$f"
      logger -t nexusplus-limit "reconciled user=$u pid=$pid limit=$limit" 2>/dev/null || true
    done
  fi
done < "$LIMITS"
