#!/usr/bin/env python3
from __future__ import annotations
import hashlib, json, os, socket, subprocess, sys
from pathlib import Path

CFG=Path(sys.argv[1] if len(sys.argv)>1 else '/etc/nexus-dnstt/server.json')

def h(p:Path)->str:
    x=hashlib.sha256()
    with p.open('rb') as f:
        for b in iter(lambda:f.read(1024*1024),b''): x.update(b)
    return x.hexdigest()

def active(unit:str)->bool:
    return subprocess.run(['systemctl','is-active','--quiet',unit],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode==0

def udp_bound(port:int)->bool:
    cp=subprocess.run(['ss','-H','-lun'],text=True,stdout=subprocess.PIPE,stderr=subprocess.DEVNULL)
    for line in cp.stdout.splitlines():
        local=line.split()[3] if len(line.split())>3 else ''
        if local.endswith(':'+str(port)) or local.endswith(']:'+str(port)):
            return True
    return False

def target_ok(target:str)->bool:
    host,port=target.rsplit(':',1)
    try:
        with socket.create_connection((host,int(port)),timeout=2): return True
    except Exception: return False

result={'component':'nexus-dnstt','config':str(CFG),'healthy':False,'checks':{},'warnings':[]}
try:
    d=json.loads(CFG.read_text())
    result['checks']['config_valid']=True
except Exception as e:
    result['checks']['config_valid']=False; result['error']=str(e); print(json.dumps(result,indent=2)); raise SystemExit(1)
try:
    listen=d['listen_udp']; port=int(listen.rsplit(':',1)[1].rstrip(']'))
    public=int(d.get('public_udp_port',53)); domain=d['tunnel_domain']; target=d['target']
    binary=Path(d.get('binary_path','/usr/local/lib/nexus-dnstt/dnstt-server'))
    expected=str(d['binary_sha256']).lower(); priv=Path(d.get('private_key_file','/etc/nexus-dnstt/server.key')); pub=Path(d.get('public_key_file','/etc/nexus-dnstt/server.pub'))
    result['domain']=domain; result['listen_udp']=listen; result['public_udp_port']=public; result['target']=target
    result['checks']['service_active']=active('nexus-dnstt.service')
    result['checks']['binary_present']=binary.is_file() and os.access(binary,os.X_OK)
    result['checks']['binary_sha256']=bool(result['checks']['binary_present'] and len(expected)==64 and h(binary)==expected)
    result['checks']['private_key_present']=priv.is_file() and priv.stat().st_size>0
    result['checks']['public_key_present']=pub.is_file() and pub.stat().st_size>0
    result['checks']['udp_listener']=udp_bound(port)
    result['checks']['ssh_target_reachable']=target_ok(target)
    if bool(d.get('firewall_redirect',True)) and public != port:
        result['checks']['firewall_redirect']=subprocess.run(['/opt/nexusplus/dnstt/nexus-dnstt-firewall','status'],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL).returncode==0
    else: result['checks']['firewall_redirect']=True
    if not result['checks']['ssh_target_reachable']:
        result['warnings'].append('Destino SSH local indisponível; o túnel não poderá abrir sessões SSH.')
    result['warnings'].append('Este health check é local. Delegação NS e conectividade DNS externa exigem teste a partir de outra rede.')
    required=['service_active','binary_present','binary_sha256','private_key_present','public_key_present','udp_listener','ssh_target_reachable','firewall_redirect']
    result['healthy']=all(result['checks'].get(k,False) for k in required)
except Exception as e:
    result['error']=str(e)
print(json.dumps(result,ensure_ascii=False,indent=2))
raise SystemExit(0 if result['healthy'] else 1)
