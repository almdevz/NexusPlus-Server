#!/usr/bin/env python3
from __future__ import annotations
import argparse, json, os, tempfile
from pathlib import Path

def die(m): raise SystemExit('[ERRO] '+m)
p=argparse.ArgumentParser(description='Gera JSON Nexus Connect não assinado com entrada DNSTT')
p.add_argument('--input',required=True); p.add_argument('--output',required=True)
p.add_argument('--domain'); p.add_argument('--public-key'); p.add_argument('--dns-server',default='1.1.1.1:53')
p.add_argument('--local-port',type=int,default=7001); p.add_argument('--mtu',type=int,default=1232)
a=p.parse_args()
server_cfg=Path('/etc/nexus-dnstt/server.json')
if server_cfg.exists():
    s=json.loads(server_cfg.read_text())
    a.domain=a.domain or s.get('tunnel_domain')
    pk=Path(s.get('public_key_file','/etc/nexus-dnstt/server.pub'))
    a.public_key=a.public_key or (pk.read_text().strip() if pk.exists() else None)
    a.dns_server=a.dns_server or s.get('client_dns_server','1.1.1.1:53')
    a.mtu=a.mtu or int(s.get('client_mtu',1232))
if not a.domain or not a.public_key: die('informe --domain e --public-key ou instale/configure o servidor DNSTT')
if not (1<=a.local_port<=65535): die('local-port inválida')
if not (512<=a.mtu<=1500): die('MTU fora de 512..1500')
src=Path(a.input); out=Path(a.output)
try: data=json.loads(src.read_text(encoding='utf-8'))
except Exception as e: die(f'JSON de entrada inválido: {e}')
if not isinstance(data,dict) or not isinstance(data.get('Servers'),list) or not isinstance(data.get('Networks'),list): die('estrutura Servers/Networks ausente')
entry={'Name':'NEXUS DNSTT','FLAG':'br.png','payload':'','sni':'','proxy_ip':'','proxyport':'','tlsport':'','connection_type':'dnstt','dnstt_dns_server':a.dns_server,'dnstt_domain':a.domain,'dnstt_public_key':a.public_key,'dnstt_local_port':a.local_port,'dnstt_mtu':a.mtu}
data['Networks']=[n for n in data['Networks'] if not (isinstance(n,dict) and (n.get('connection_type')=='dnstt' or n.get('Name')=='NEXUS DNSTT'))]
data['Networks'].append(entry); data['ConfigSignature']=''
out.parent.mkdir(parents=True,exist_ok=True)
fd,tmp=tempfile.mkstemp(prefix='.dnstt-config-',dir=str(out.parent)); os.close(fd)
Path(tmp).write_text(json.dumps(data,ensure_ascii=False,indent=2)+'\n',encoding='utf-8'); os.chmod(tmp,0o600); os.replace(tmp,out)
print(f'[OK] Gerado: {out}')
print(f'[INFO] Servers preservados: {len(data["Servers"])}')
print(f'[INFO] Networks finais: {len(data["Networks"])}')
print('[AVISO] ConfigSignature foi esvaziada. Assine com o Nexus JSON Signer antes de publicar.')
